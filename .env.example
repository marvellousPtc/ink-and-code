# ============================================
# Ink & Code 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# [必需] PostgreSQL 数据库连接串
DATABASE_URL=postgresql://user:password@localhost:5432/ink_and_code

# [必需] 管理后台 API 密钥
ADMIN_API_KEY=your-admin-api-key

# [必需] DeepSeek API 密钥（备用，主要通过 Cortex 调用）
DEEPSEEK_API_KEY=sk-xxx

# [必需] NextAuth 加密密钥（可通过 openssl rand -base64 32 生成）
AUTH_SECRET=your-auth-secret

# [必需] GitHub OAuth 应用凭据
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# [必需] Google OAuth 应用凭据
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# [必需] NextAuth 回调地址，本地开发为 http://localhost:3000
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# [可选] 阿里云 OSS 默认图床配置
# DEFAULT_OSS_REGION=oss-cn-beijing
# DEFAULT_OSS_BUCKET=your-bucket
# DEFAULT_OSS_ACCESS_KEY_ID=
# DEFAULT_OSS_ACCESS_KEY_SECRET=
# DEFAULT_OSS_DIR=public

# [可选] 开发者 Token，用于管理员操作和 CI 自动发布
# DEVELOPER_TOKEN=ink_xxx

# ============================================
# PTC Cortex AI 服务集成
# ink-and-code 通过以下配置连接 ptc-cortex AI 服务
# ============================================

# [必需] Cortex API 地址，供 /api/chat 和 /api/ai/writing 代理调用
# 本地开发: http://localhost:3001  生产环境: http://localhost:3001 或内网地址
CORTEX_API_URL=http://localhost:3001

# [必需] Cortex 内部地址，供 Next.js rewrites 代理 /chat/* 页面
# 通常和 CORTEX_API_URL 相同
CORTEX_INTERNAL_URL=http://localhost:3001

# [必需] Cortex API 鉴权密钥，对应 ptc-cortex 的 API_SECRET_KEY
CORTEX_API_KEY=sk-your-cortex-api-key

# [可选] AI 每日调用次数限制，默认 20 次/天（管理员不限）
# AI_DAILY_LIMIT=20

# ============================================
# 本地开发代理（可选）
# 设置后本地 /api/* 请求会代理到线上服务器
# ============================================

# PRODUCTION_URL=https://your-production-domain.com
# PROXY_TOKEN=your-proxy-token
